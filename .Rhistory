B <- bell.labs$A
Z <- bell.labs$X
x <- bell.labs$Y
library(lattice)
traffic.in <- c("dst fddi", "dst switch", "dst local", "dst corp")
traffic.out <- c("src fddi", "src local", "src corp")
my.df <- bell.labs$df
my.df$t <- unlist(lapply(my.df$time, function(x) {
hrs <- as.numeric(substring(x, 11, 12))
mins <- as.numeric(substring(x, 14, 15))
t <- hrs + mins/60
return(t)}))
my.df.in <- subset(my.df, nme %in% traffic.in)
my.df.out <- subset(my.df, nme %in% traffic.out)
p.in <- xyplot(value / 2^10 ~ t | nme, data=my.df.in, type="l", col.line="goldenrod", lwd=2, layout=c(1, 4), xlab="Hora del día", ylab="Kbytes/seg")
p.out <- xyplot(value / 2^10 ~ t | nme, data=my.df.out, type="l", col.line="red", lwd=2, layout=c(1, 4), xlab="Hora del día", ylab="Kbytes/seg")
print(p.in, position=c(0, 0.5, 1, 1), more=TRUE)
print(p.out, position=c(0, 0, 1, 0.5))
