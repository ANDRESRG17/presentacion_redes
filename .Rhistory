# --- MEJORA VISUAL: Ajustes estéticos para la presentación ---
# Esto hace que los títulos de cada panel (strips) tengan un fondo blanco o crema claro
# en lugar del gris oscuro/rosado que viene por defecto, viéndose mucho más profesional.
mi_tema <- list(strip.background = list(col = "#F5F5F5"))
# Gráfico Superior (Entradas)
p.in <- xyplot(value / 2^10 ~ t | nme,
data = my.df.in,
type = "l",
col.line = "goldenrod",   # Color mostaza/dorado
lwd = 2,                  # Líneas gruesas para el proyector
layout = c(1, 4),         # 1 columna, 4 filas
xlab = "",                # Quitamos el label de X aquí para no repetirlo
ylab = "Kbytes/seg",
par.settings = mi_tema)
# Gráfico Inferior (Salidas)
p.out <- xyplot(value / 2^10 ~ t | nme,
data = my.df.out,
type = "l",
col.line = "firebrick",  # Color rojo ladrillo
lwd = 2,
layout = c(1, 4),
xlab = "Hora del día",   # Solo dejamos el label de X en el de abajo
ylab = "Kbytes/seg",
par.settings = mi_tema)
# --- APILAR LOS GRÁFICOS ---
# El parámetro 'position' usa coordenadas c(xmin, ymin, xmax, ymax) de 0 a 1
# p.in ocupa la mitad superior (y va de 0.5 a 1)
print(p.in, position = c(0, 0.5, 1, 1), more = TRUE)
# p.out ocupa la mitad inferior (y va de 0 a 0.5)
print(p.out, position = c(0, 0, 1, 0.5))
B.full <- rbind(B, 2 - colSums(B))
write.table(format(B.full), row.names=F, col.names=F, quote=F)
