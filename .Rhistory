par(mar=c(0, 0, 0, 0)) # Quitamos los márgenes blancos
set.seed(42)
plot(g.bl,
layout = mi_layout_bl,
xlim = c(-1, 1),  # Un poco de espacio para que no se corten los nombres
ylim = c(-1, 1),
# --- Configuración de Nodos ---
vertex.size = 29,                 # Nodos grandes y visibles
vertex.color = colores_nodos,     # Aplicamos los colores que definimos arriba
vertex.frame.color = "#a8a8a8",    # Borde oscuro para darle contraste
# --- Configuración de Texto ---
vertex.label.family = "sans",
vertex.label.font = 3,            # 2 = Negrita
vertex.label.cex = 1,           # Letra grande
vertex.label.color = "#5C5C5C",
# --- Configuración de Enlaces ---
edge.width = 1.4,
edge.arrow.size = 1.2,            # Flechas medianas
edge.curved = 0,                # TRUCO 3: Curvatura vital para separar las flechas de ida y vuelta
edge.color = "#a8a8a8"
)
