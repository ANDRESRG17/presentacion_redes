# Instalar los paquetes si no los tienes:
# install.packages(c("igraph", "ggraph", "tidygraph"))
library(igraph)
library(ggraph)
library(tidygraph)
# 1. Definir las aristas (edges) y los flujos
# Simulamos una red de movilidad con nodos de origen, destino y un volumen de flujo
edges <- data.frame(
from = c("Portal Norte", "Portal Norte", "Calle 100", "Calle 100", "NQS", "Autonorte", "Héroes"),
to = c("Calle 100", "Autonorte", "Héroes", "NQS", "Centro", "Héroes", "Centro"),
flujo = c(500, 300, 450, 200, 600, 250, 550) # El peso o capacidad de la red
)
# 2. Definir los nodos (opcional, pero buena práctica para asegurar que todos estén)
nodes <- data.frame(
name = unique(c(edges$from, edges$to))
)
# 3. Convertir a objeto tbl_graph
# directed = TRUE es clave para que sea un digrafo
grafo_flujo <- tbl_graph(nodes = nodes, edges = edges, directed = TRUE)
# 4. Visualización con ggraph
ggraph(grafo_flujo, layout = 'sugiyama') + # El layout 'sugiyama' es ideal para redes dirigidas
# Dibujar las flechas y ajustar su apariencia según el flujo
geom_edge_link(aes(width = flujo, color = flujo),
arrow = arrow(length = unit(3, 'mm'), type = "closed"),
end_cap = circle(6, 'mm'), # Evita que la flecha se meta debajo del nodo
alpha = 0.8) +
# Dibujar los nodos
geom_node_point(size = 8, color = "#2c3e50") +
# Etiquetas de los nodos
geom_node_text(aes(label = name), vjust = 2, hjust = 0.5,
size = 4, fontface = "bold", color = "#34495e") +
# Escalas estéticas para el grosor y color de las flechas
scale_edge_width(range = c(0.8, 3.5), guide = "none") +
scale_edge_color_viridis(option = "C", direction = -1) +
# Tema limpio para grafos
theme_graph() +
labs(title = "Red de Flujo Direccional",
subtitle = "Análisis de volumen y capacidad",
edge_color = "Volumen\nde Flujo") +
theme(legend.position = "right")
# Instalar paquetes necesarios si no los tienes:
# install.packages(c("igraph", "ggraph", "tidygraph", "ggrepel"))
library(igraph)
library(ggraph)
library(tidygraph)
# 1. Definir los datos de flujo comercial (ej. millones de dólares)
edges <- data.frame(
from = c("Nueva York", "Londres", "Tokio", "Singapur", "Nueva York", "Fráncfort", "Tokio", "Londres", "Singapur"),
to = c("Londres", "Fráncfort", "Singapur", "Tokio", "Tokio", "Nueva York", "Londres", "Singapur", "Fráncfort"),
volumen = c(450, 320, 600, 550, 200, 380, 410, 290, 310)
)
nodes <- data.frame(name = unique(c(edges$from, edges$to)))
# 2. Convertir a tbl_graph
grafo_comercio <- tbl_graph(nodes = nodes, edges = edges, directed = TRUE)
# 3. Visualización de alto impacto
ggraph(grafo_comercio, layout = 'circle') + # Un diseño circular es muy estético para ciudades
# Aristas curvas (geom_edge_arc) con gradiente de color según la dirección
geom_edge_arc(aes(width = volumen, color = after_stat(index)),
arrow = arrow(length = unit(4, 'mm'), type = "closed"),
end_cap = circle(9, 'mm'), # Espacio para que la flecha no pise el nodo
alpha = 0.8,
strength = 0.3) + # 'strength' controla qué tan curva es la línea
# Nodos minimalistas pero llamativos
geom_node_point(size = 12, color = "#00d2ff", fill = "#3a7bd5", shape = 21, stroke = 1.5) +
# Etiquetas de los nodos (usando repel para que no se amontonen)
geom_node_text(aes(label = name), repel = TRUE, size = 5,
color = "white", fontface = "bold") +
# Escalas de diseño
scale_edge_width(range = c(0.5, 3.5), guide = "none") +
scale_edge_color_viridis(option = "plasma", guide = "none") + # Gradiente cálido/brillante
# Tema oscuro y limpio
theme_void() +
theme(
plot.background = element_rect(fill = "#1a1a2e", color = NA),
panel.background = element_rect(fill = "#1a1a2e", color = NA),
plot.title = element
library(igraph)
library(ggraph)
library(tidygraph)
# ---------------------------------------------------------
# 1. Adaptar TUS datos (Asegúrate de que tu data.frame se llame 'datos')
# Aquí genero unos datos de prueba con tu estructura para que corra
datos <- data.frame(
Orig = c("A", "A", "B", "C", "D"),
Dest = c("B", "C", "A", "D", "A"),
DistEuc = c(10, 15, 10, 20, 25), # No lo usamos en el grafo, pero está en tus datos
Flow = c(100, 250, 150, 300, 200) # Tu variable de flujo
)
# Filtramos solo las columnas que el grafo necesita: Origen, Destino y Flujo
edges <- datos[, c("Orig", "Dest", "Flow")]
nodes <- data.frame(name = unique(c(edges$Orig, edges$Dest)))
# 2. Crear el objeto de red (Digrafo)
grafo_flujo <- tbl_graph(nodes = nodes, edges = edges, directed = TRUE)
# ---------------------------------------------------------
# 3. Gráfico estético completo (Cópialo todo junto)
ggraph(grafo_flujo, layout = 'circle') +
# Aristas curvas mapeadas a TU columna 'Flow'
geom_edge_arc(aes(width = Flow, color = after_stat(index)),
arrow = arrow(length = unit(4, 'mm'), type = "closed"),
end_cap = circle(9, 'mm'),
alpha = 0.8,
strength = 0.3) +
# Nodos
geom_node_point(size = 12, color = "#00d2ff", fill = "#3a7bd5", shape = 21, stroke = 1.5) +
# Etiquetas
geom_node_text(aes(label = name), repel = TRUE, size = 5,
color = "white", fontface = "bold") +
# Escalas (Aquí es donde se te cortó antes. ¡Ya está completo!)
scale_edge_width(range = c(0.5, 3.5), guide = "none") +
scale_edge_color_viridis(option = "plasma", guide = "none") +
# Tema oscuro estético
theme_void() +
theme(
plot.background = element_rect(fill = "#1a1a2e", color = NA),
panel.background = element_rect(fill = "#1a1a2e", color = NA),
plot.title = element_text(color = "white", size = 22, face = "bold", hjust = 0.5, margin = margin(t = 20, b = 5)),
plot.subtitle = element_text(color = "#a9a9b3", size = 14, hjust = 0.5, margin = margin(b = 30)),
plot.margin = margin(20, 20, 20, 20)
) +
labs(title = "Red de Flujos Direccionales",
subtitle = "Visualización basada en matriz de origen y destino")
# Instalar los paquetes necesarios si aún no los tienes
# install.packages(c("igraph", "ggraph", "ggplot2"))
library(igraph)
library(ggraph)
library(ggplot2)
# ==============================================================================
# 1. GENERACIÓN DE DATOS SIMULADOS
# ==============================================================================
# Creamos una grilla de puntos y eliminamos algunos para dar forma irregular
set.seed(123)
grid_side <- 10
nodes <- expand.grid(x = 1:grid_side, y = 1:grid_side)
nodes <- nodes[sample(nrow(nodes), 70), ] # Nos quedamos con 70 nodos
nodes$id <- 1:nrow(nodes)
# Asignar tipos de nodo aleatorios para la leyenda
# 1: Unobserved intersection, 2: Unobserved O-D, 3: Observed intersection, 4: Observed O-D
node_types <- c("Unobserved intersection",
"Unobserved origin destination",
"Observed intersection",
"Observed origin destination")
nodes$type_code <- sample(1:4, nrow(nodes), replace = TRUE, prob = c(0.1, 0.2, 0.3, 0.4))
nodes$node_type <- factor(node_types[nodes$type_code], levels = node_types)
# Crear aristas basadas en proximidad (para que parezca una red de calles)
edges <- data.frame(from = integer(), to = integer())
for (i in 1:(nrow(nodes)-1)) {
for (j in (i+1):nrow(nodes)) {
dist <- sqrt((nodes$x[i] - nodes$x[j])^2 + (nodes$y[i] - nodes$y[j])^2)
if (dist < 1.5) { # Conectar si están cerca
# Para hacerlo dirigido, aleatoriamente decidimos el sentido
if (runif(1) > 0.5) {
edges <- rbind(edges, data.frame(from = nodes$id[i], to = nodes$id[j]))
} else {
edges <- rbind(edges, data.frame(from = nodes$id[j], to = nodes$id[i]))
}
}
}
}
# Contar cuántos nodos hay de cada tipo para incluirlo en la leyenda
type_counts <- table(nodes$node_type)
legend_labels <- paste0(names(type_counts), " (", type_counts, ")")
names(legend_labels) <- names(type_counts)
# ==============================================================================
# 2. CREACIÓN DEL OBJETO DE GRAFO
# ==============================================================================
# directed = TRUE asegura que sea un digrafo (con flechas)
g <- graph_from_data_frame(d = edges, vertices = nodes, directed = TRUE)
# Instalar los paquetes necesarios si aún no los tienes
# install.packages(c("igraph", "ggraph", "ggplot2"))
library(igraph)
library(ggraph)
library(ggplot2)
# ==============================================================================
# 1. GENERACIÓN DE DATOS SIMULADOS
# ==============================================================================
# Creamos una grilla de puntos y eliminamos algunos para dar forma irregular
set.seed(123)
grid_side <- 10
nodes <- expand.grid(x = 1:grid_side, y = 1:grid_side)
nodes <- nodes[sample(nrow(nodes), 70), ] # Nos quedamos con 70 nodos
nodes$id <- 1:nrow(nodes)
# Asignar tipos de nodo aleatorios para la leyenda
# 1: Unobserved intersection, 2: Unobserved O-D, 3: Observed intersection, 4: Observed O-D
node_types <- c("Unobserved intersection",
"Unobserved origin destination",
"Observed intersection",
"Observed origin destination")
nodes$type_code <- sample(1:4, nrow(nodes), replace = TRUE, prob = c(0.1, 0.2, 0.3, 0.4))
nodes$node_type <- factor(node_types[nodes$type_code], levels = node_types)
# Crear aristas basadas en proximidad (para que parezca una red de calles)
edges <- data.frame(from = integer(), to = integer())
for (i in 1:(nrow(nodes)-1)) {
for (j in (i+1):nrow(nodes)) {
dist <- sqrt((nodes$x[i] - nodes$x[j])^2 + (nodes$y[i] - nodes$y[j])^2)
if (dist < 1.5) { # Conectar si están cerca
# Para hacerlo dirigido, aleatoriamente decidimos el sentido
if (runif(1) > 0.5) {
edges <- rbind(edges, data.frame(from = nodes$id[i], to = nodes$id[j]))
} else {
edges <- rbind(edges, data.frame(from = nodes$id[j], to = nodes$id[i]))
}
}
}
}
# Contar cuántos nodos hay de cada tipo para incluirlo en la leyenda
type_counts <- table(nodes$node_type)
legend_labels <- paste0(names(type_counts), " (", type_counts, ")")
names(legend_labels) <- names(type_counts)
# ==============================================================================
# 2. CREACIÓN DEL OBJETO DE GRAFO
# ==============================================================================
# directed = TRUE asegura que sea un digrafo (con flechas)
# Así garantizas que cada nodo exista una sola vez
nodes <- data.frame(
name = unique(c(edges$from, edges$to))
)
# Y luego creas el grafo
g <- graph_from_data_frame(d = edges, vertices = nodes, directed = TRUE)
# ==============================================================================
# 3. VISUALIZACIÓN ESTÉTICA CON GGRAPH
# ==============================================================================
# Definir la paleta de colores exacta de la imagen de referencia
transporte_colors <- c(
"Unobserved intersection" = "#e91e63",          # Rosa
"Unobserved origin destination" = "#f5a623",    # Naranja
"Observed intersection" = "#00897b",           # Verde azulado
"Observed origin destination" = "#616161"      # Gris
)
# Crear el gráfico
ggplot_graph <- ggraph(g, layout = 'manual', x = V(g)$x, y = V(g)$y) +
# Dibujar las aristas con flechas al final
geom_edge_link(arrow = arrow(length = unit(2, 'mm'), type = "closed"),
color = "#757575", alpha = 0.7, start_cap = circle(1.5, 'mm'), end_cap = circle(1.5, 'mm')) +
# Dibujar los nodos con colores según su tipo
geom_node_point(aes(color = node_type), size = 4) +
# Configurar la escala de colores y la leyenda
scale_color_manual(values = transporte_colors, labels = legend_labels, name = NULL) +
# Usar un tema completamente blanco/vacío
theme_void() +
# Ajustes de la leyenda para que se parezca a la referencia
theme(
legend.position = c(0.8, 0.2), # Colocar la leyenda abajo a la derecha
legend.background = element_rect(fill = "white", color = NA),
legend.text = element_text(size = 10),
legend.key = element_blank(),
plot.margin = margin(20, 20, 20, 20)
)
