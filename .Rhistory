vertex.label.cex = 1,           # Letra grande
vertex.label.color = "#77777A",
# --- Configuración de Enlaces ---
edge.width = 2,
edge.arrow.size = 1,            # Flechas medianas
edge.curved = 0,                # TRUCO 3: Curvatura vital para separar las flechas de ida y vuelta
edge.color = "#a8a8a8"
)
